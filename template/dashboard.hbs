<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Latest News - Your Favorite App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" type="text/css" href="/styles1.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
          <a class="navbar-brand" href="#">Latest News</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/?q=all&pageno=1">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=India&pageno=1">India</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=World&pageno=1">World</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=Sports&pageno=1">Sports</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=Technology&pageno=1">Technology</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=Entertainment&pageno=1">Entertainment</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=Health&pageno=1">Health</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=Weather&pageno=1">Weather</a></li>
              <li class="nav-item"><a class="nav-link" href="/?q=Business&pageno=1">Business</a></li>
            </ul> 
            <form class="d-flex" role="search">
              <input class="form-control me-2" name="q" type="search" placeholder="Search" aria-label="Search">
              <input class="form-control me-2" name="pageno" type="hidden" value="1">
              <button class="btn btn-outline-success" type="submit">Search</button>
            </form>
            <form class="d-flex">
              <!-- Advanced Search Dropdown -->
              <div class="dropdown me-2">
                <button class="btn btn-secondary dropdown-toggle" type="button" id="advancedSearchDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                  Advanced Search
                </button>
                <div class="dropdown-menu p-3">
                  <label for="sortBy" class="form-label">Sort By:</label>
                  <select class="form-select mb-2" id="sortBy">
                    <option value="relevancy">Relevancy</option>
                    <option value="popularity">Popularity</option>
                    <option value="publishedAt">Latest</option>
                  </select>
            
                  <label for="fromDate" class="form-label">From Date:</label>
                  <input type="date" class="form-control mb-2" id="fromDate">
            
                  <label for="toDate" class="form-label">To Date:</label>
                  <input type="date" class="form-control mb-2" id="toDate">
            
                  <label for="language" class="form-label">Language:</label>
                  <select class="form-select mb-2" id="language">
                    <option value="en">English</option>
                    <option value="hi">Hindi</option>
                    <option value="es">Spanish</option>
                    <option value="fr">French</option>
                  </select>
            
                  <button class="btn btn-primary w-100" type="button" onclick="applyAdvancedSearch()">Apply</button>
                </div>
              </div>
            </form>

            <div class="user-info text-end">
              <p class="mb-0"><strong>Welcome,{{user.name}}!</strong></p>
              <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
          </div> 
            
          </div>
        </div>
    </nav>

    <div class="container mx-auto">
      <h1 class="text-center my-2"><span id="queryText"></span> News (<span id="queryResults"></span> results)</h1>
      <div id="content" class="row">
        <div class="d-flex justify-content-center">
          <img width="50" src="https://samherbert.net/svg-loaders/svg-loaders/oval.svg" style="filter:invert(1)">
        </div>
      </div>

      <div class="prev-next d-flex justify-content-center"> 
        <nav aria-label="Page navigation example">
          <ul class="pagination">
            <li class="page-item"><a id="pre" class="page-link" href="#">Previous</a></li>
            <li class="page-item"><a id="page-1" class="page-link" href="#">1</a></li>
            <li class="page-item"><a id="page-2" class="page-link" href="#">2</a></li>
            <li class="page-item"><a id="page-3" class="page-link" href="#">3</a></li>
            <li class="page-item"><a id="next" class="page-link" href="#">Next</a></li>
          </ul>
        </nav>
      </div>
    </div>    

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
      let articlesPerPage = 10;

      // Get query and pageno from the URL
      const params = new URLSearchParams(window.location.search);
      let query = params.get("q") || "all";  // Default to 'all' if no query is specified
      let pageno = parseInt(params.get("pageno")) || 1;

      const fetchNews = async (query, pageno) => {
        try {
          // Use the query in the API request URL
          const response = await fetch(`https://newsapi.org/v2/everything?q=${query}&apiKey=a68f30fe1b5d4da3a7f528086f6e0521&pageSize=${articlesPerPage}&page=${pageno}`);
          
          if (!response.ok) throw new Error("Failed to fetch news");

          const data = await response.json();
          console.log(data);

          // Update query text and results
          document.getElementById("queryText").innerText = query.replace("+", " ");
          document.getElementById("queryResults").innerText = data.totalResults;

          // Calculate total pages for pagination
          totalPages = Math.ceil(data.totalResults / articlesPerPage);

          // Update navigation links
          document.getElementById("pre").href = pageno > 1 ? `/?q=${query}&pageno=${pageno - 1}` : "#";
          document.getElementById("next").href = pageno < totalPages ? `/?q=${query}&pageno=${pageno + 1}` : "#";

          // Populate news cards
          let str = "";
          for (let item of data.articles) {
            let date = new Date(item.publishedAt).toLocaleDateString();
            str += `
              <div class="card m-2" style="width: 18rem;">
                <img src="${item.urlToImage || 'https://via.placeholder.com/150'}" class="card-img-top" alt="Image">
                <div class="card-body">
                  <h5 class="card-title">${item.title}</h5>
                  <span class="font-fw-bold">Published: ${date}</span>
                  <p class="card-text">${item.description || "No description available."}</p>
                  <a target="_blank" href="${item.url}" class="btn btn-primary">Read More...</a>
                </div>
              </div>`;
          }
          document.getElementById("content").innerHTML = str;
        } catch (error) {
          document.getElementById("content").innerHTML = `<div class="alert alert-danger">Error: ${error.message}</div>`;
        }
      };

      // Call the fetch function with current query and page number
      fetchNews(query, pageno);
    </script>
    <script>
        async function sendMessage() {
            let inputField = document.getElementById("userInput");
            let message = inputField.value;
            inputField.value = "";
    
            document.getElementById("chatbox").innerHTML += `<p><b>You:</b> ${message}</p>`;
    
            let response = await fetch("/chat", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ message })
            });
    
            let data = await response.json();
            document.getElementById("chatbox").innerHTML += `<p><b>AI:</b> ${data.reply}</p>`;
        }
    </script>
    
  </body>
</html>

